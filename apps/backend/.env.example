# Copy to .env (dev.sh does this automatically). All values below are safe local
# dev defaults — no real secrets.
DATABASE_URL="postgresql://sixer:sixer@127.0.0.1:5432/sixer?schema=public"
PORT=4000
JWT_SECRET="dev-sixer-secret-change-me"
VENUE_TZ="Asia/Kolkata"

# OTP request rate limit per IP / 10 min (dev default a bit higher for testing).
OTP_RATE_MAX=20

# Payment provider: leave RAZORPAY_KEY_ID unset to use the deterministic MOCK.
# Razorpay test-mode keys are free with no KYC:
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
# RAZORPAY_WEBHOOK_SECRET=xxx

# SMS provider: unset => MOCK (OTP logged + served at GET /dev/last-otp).
# SMS_PROVIDER=twilio
# TWILIO_SID=...
# TWILIO_TOKEN=...
# TWILIO_FROM=+1...

# Email OTP login. Unset SMTP_USER/SMTP_PASS => DEV mode (code logged and shown
# in the app so login works with no account). Set them to send real email.
# For Gmail: create an App Password (Google Account → Security → App passwords;
# requires 2-Step Verification) and use it as SMTP_PASS.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=Sixer Arena <you@gmail.com>
